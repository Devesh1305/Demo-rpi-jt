        qr = qrcode.QRCode(version=3, box_size=15, border=4)
        qr.add_data(text)
        qr.make(fit=True)
        img_pil = qr.make_image(fill_color="black", back_color="white")
        return cv2.cvtColor(np.array(img_pil), cv2.COLOR_RGB2BGR)
    
