                     (user_choice == "Scissors" and ai_choice == "Paper"):
                    res = f"You Win! {user_choice} beats {ai_choice}!"
                    st.session_state.rps_user_score += 1
                else:
                    res = f"AI Wins! {ai_choice} beats {user_choice}!"
                    st.session_state.rps_ai_score += 1
                    
                st.session_state.rps_result_text = res
                st.session_state.rps_state = 'completed'
                st.session_state.rps_countdown_start = curr_t # Track time since reveal
                st.toast(f"Result: {res}")
                
            elif st.session_state.rps_state == 'completed':
                # Display game results on overlay for 5 seconds
                elapsed = curr_t - st.session_state.rps_countdown_start
                if elapsed < 5.0:
                    game_overlay_text = f"RESULT: {st.session_state.rps_result_text}"
                    overlay_color = (0, 255, 0) # Green
                else:
                    st.session_state.rps_state = 'idle'
            
            # Draw game overlay text
            if game_overlay_text:
                cv2.putText(
                    frame, game_overlay_text, (40, 60),
                    cv2.FONT_HERSHEY_SIMPLEX, 1.0, overlay_color, 3, cv2.LINE_AA
                )
                
            # Draw Pause overlay if frozen
            if st.session_state.paused:
                overlay = frame.copy()
                cv2.rectangle(overlay, (0, 0), (w, h), (30, 30, 30), -1)
                alpha = 0.6
                frame = cv2.addWeighted(overlay, alpha, frame, 1 - alpha, 0)
                cv2.putText(
                    frame, "PIPELINE FROZEN", (w // 2 - 160, h // 2),
                    cv2.FONT_HERSHEY_SIMPLEX, 1.0, (255, 255, 255), 3, cv2.LINE_AA
                )
                cv2.putText(
                    frame, "Hold Fist ✊ to Resume", (w // 2 - 170, h // 2 + 50),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.7, (200, 200, 200), 2, cv2.LINE_AA
                )
                
            # Draw Peace Quote overlay if active
            if st.session_state.quote_overlay and curr_t < st.session_state.quote_overlay_expiry:
                # Wrap quote in a visual banner at the bottom of the video frame
                cv2.rectangle(frame, (10, h - 60), (w - 10, h - 10), (10, 10, 12), -1)
                cv2.rectangle(frame, (10, h - 60), (w - 10, h - 10), 
                              tuple(int(accent_hex[i:i+2], 16) for i in (5, 3, 1)), 1)
                cv2.putText(
                    frame, st.session_state.quote_overlay, (20, h - 30),
                    cv2.FONT_HERSHEY_SIMPLEX, 0.42, (255, 255, 255), 1, cv2.LINE_AA
                )
            
            # 4. Compress to JPEG and Stream over WebSockets
            _, jpeg_buffer = cv2.imencode('.jpg', frame, [int(cv2.IMWRITE_JPEG_QUALITY), 80])
            video_placeholder.image(jpeg_buffer.tobytes(), use_container_width=True)

            # Timing & FPS tracking
            now = time.perf_counter()
            fps = 1.0 / (now - last_time) if (now - last_time) > 0 else 0
            last_time = now
            fps_history.append(fps)
            if len(fps_history) > 30:
                fps_history.pop(0)
            avg_fps = np.mean(fps_history)
            st.session_state.fps_history = fps_history

            # Update Metrics placeholders
            fps_placeholder.markdown(f"""
                <div class="metric-container">
                    <div class="metric-label">Pipeline Frame Rate</div>
                    <div class="metric-value">{avg_fps:.1f} FPS</div>
                    <div class="metric-sub">MediaPipe downscaled core loop</div>
                </div>
            """, unsafe_allow_html=True)
            
            active_hand_str = ", ".join(detected_hands_info) if detected_hands_info else "No hand detected"
            hand_placeholder.markdown(f"""
                <div class="metric-container">
                    <div class="metric-label">Tracked Hands</div>
                    <div class="metric-value" style="color: {accent_hex}; font-size: 16px; margin-top: 6px;">{active_hand_str}</div>
                    <div class="metric-sub">Multi-handedness index tracking</div>
                </div>
            """, unsafe_allow_html=True)

            gesture_output_placeholder.markdown(f"""
                <div class="gesture-card">
                    <div class="gesture-emoji">{primary_emoji}</div>
                    <div class="gesture-title">{primary_gesture}</div>
                    <div style="font-size: 12px; color: #a0a0a5; margin-top: 5px;">Primary Hand Gesture</div>
                </div>
            """, unsafe_allow_html=True)

            # RPS Game Card
            status_text = "Waiting to play..."
            if st.session_state.rps_state == 'countdown':
                status_text = "GET READY!"
            elif st.session_state.rps_state == 'completed':
                status_text = f"AI Gesture: {st.session_state.rps_ai_gesture}"

            rps_card_placeholder.markdown(f"""
                <div style="background: rgba(255, 255, 255, 0.02); border-radius: 10px; padding: 12px; border: 1px solid rgba(255,255,255,0.06);">
                    <div style="display: flex; justify-content: space-between; font-weight: bold; margin-bottom: 8px;">
                        <span>👤 Player Score: {st.session_state.rps_user_score}</span>
                        <span>🤖 Jetson AI Score: {st.session_state.rps_ai_score}</span>
                    </div>
                    <div style="font-size: 13px; color: #a0a0a5; text-align: center;">{status_text}</div>
                    {f'<div style="font-size: 12px; font-weight: bold; color: {accent_hex}; text-align: center; margin-top: 5px;">{st.session_state.rps_result_text}</div>' if st.session_state.rps_state == 'completed' else ''}
                </div>
            """, unsafe_allow_html=True)
            
            # Trigger Events Logs
            active_events = []
            if st.session_state.paused:
                active_events.append("⏸️ Pipeline Muted (Fist)")
            if now < st.session_state.quote_overlay_expiry:
                active_events.append("✌️ Quote Overlay Enabled")
            if curr_t - st.session_state.get('last_snapshot_time', 0) < 2.0:
                active_events.append("📸 Saving Camera Snapshot")
            if st.session_state.get('hand_velocity', 0) > 1000:
                active_events.append("💨 Fast Motion Detected!")

            events_str = "<br>".join([f"• {ev}" for ev in active_events]) if active_events else "• No active trigger events"
            trigger_placeholder.markdown(f"""
                <div style="background: rgba(255, 255, 255, 0.01); border-radius: 8px; padding: 10px; border: 1px dashed rgba(255,255,255,0.1); font-size: 13px; color: #d1d1d6; line-height: 1.6;">
                    {events_str}
                </div>
            """, unsafe_allow_html=True)

            # Trigger balloons outside lock to prevent lagging
            if st.session_state.trigger_balloons:
                st.session_state.trigger_balloons = False
                st.balloons()

            time.sleep(0.001)

    else:
        st.info("💡 Start the webcam pipeline using the checkbox in the control panel.")
        if 'cam' in st.session_state and st.session_state.cam is not None:
            st.session_state.cam.close()
            st.session_state.cam = None

