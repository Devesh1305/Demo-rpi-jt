def get_cpu_temp():
    """Retrieves CPU temperature if available on Linux/Jetson."""
    if sys.platform.startswith('linux'):
        for i in range(5):
            path = f"/sys/class/thermal/thermal_zone{i}/temp"
            if os.path.exists(path):
                try:
                    with open(path, 'r') as f:
                        temp = float(f.read().strip()) / 1000.0
                        return f"{temp:.1f}°C"
                except Exception:
                    pass
    return "38.5°C (Simulated)"

def get_jetson_stats():
    """Retrieves system performance stats on Jetson or falls back gracefully."""
    stats = {"cpu_util": "N/A", "gpu_util": "N/A", "ram_util": "N/A", "power_mode": "N/A"}
    
    # Try using psutil for CPU/RAM usage
    try:
        import psutil
        stats["cpu_util"] = f"{psutil.cpu_percent()}%"
        stats["ram_util"] = f"{psutil.virtual_memory().percent}%"
    except ImportError:
        # Fallback reading proc load
        if sys.platform.startswith('linux'):
            try:
                with open('/proc/loadavg', 'r') as f:
                    load = f.read().split()[0]
                    stats["cpu_util"] = f"{float(load)*100/4:.1f}%"
            except Exception:
                pass
                
    # GPU Utilization pathways on NVIDIA Jetson Tegra GPUS
    gpu_paths = [
        "/sys/devices/platform/17000000.ga10b/load", # Orin Nano
        "/sys/devices/17000000.gp10b/load",        # Tegra GP10B
        "/sys/class/devfreq/gp10b/device/load",
        "/sys/devices/gpu.0/load"
    ]
    for path in gpu_paths:
        if os.path.exists(path):
            try:
                with open(path, 'r') as f:
                    val = int(f.read().strip())
                    if val > 100:
                        val = val // 10
                    stats["gpu_util"] = f"{val}%"
                    break
            except Exception:
                pass
                
    if stats["gpu_util"] == "N/A":
        stats["gpu_util"] = "18% (Simulated)" if not sys.platform.startswith('linux') else "0%"
        
    # NVPModel (Power Mode) on Jetson Linux
    if sys.platform.startswith('linux'):
        try:
            import subprocess
            out = subprocess.check_output(["nvpmodel", "-q"], stderr=subprocess.DEVNULL).decode('utf-8')
            for line in out.split('\n'):
                if "Mode" in line or "NV Power Mode" in line:
                    stats["power_mode"] = line.split(':')[-1].strip()
                    break
        except Exception:
            pass
            
    if stats["power_mode"] == "N/A":
        stats["power_mode"] = "MODE_15W"
        
    return stats

