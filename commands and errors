# ----------------- RECOGNITION BACKGROUND WORKER -----------------
def recognition_loop():
    camera = st.session_state.camera
    shared = st.session_state.shared_results
    lock = st.session_state.results_lock
    
    detection_model = "cnn" if "CNN" in model_type else "hog"
    
    while st.session_state.worker_running:
        ret, frame = camera.read()
        if not ret or frame is None:
            time.sleep(0.01)
            continue
            
        start_time = time.time()
        
        # Performance resizing
        resized = cv2.resize(frame, (0, 0), fx=(1/cv_scaler), fy=(1/cv_scaler))
        rgb_resized = cv2.cvtColor(resized, cv2.COLOR_BGR2RGB)
        
        # Run detection & encoding
        # Try CNN, fallback to HOG if OOM occurs
        try:
            face_locations = face_recognition.face_locations(rgb_resized, model=detection_model)
        except RuntimeError as e:
            if "out of memory" in str(e).lower() and detection_model == "cnn":
                face_locations = face_recognition.face_locations(rgb_resized, model="hog")
            else:
                face_locations = []
                
        face_encodings = face_recognition.face_encodings(rgb_resized, face_locations)
        
        face_names = []
        face_distances = []
        
        for face_encoding in face_encodings:
            matches = face_recognition.compare_faces(known_face_encodings, face_encoding, tolerance=tolerance)
            name = "Unknown"
            best_dist = 1.0
            
            distances = face_recognition.face_distance(known_face_encodings, face_encoding)
            if len(distances) > 0:
                best_match_idx = np.argmin(distances)
                best_dist = distances[best_match_idx]
                if matches[best_match_idx]:
                    name = known_face_names[best_match_idx]
                    
            face_names.append(name)
            face_distances.append(best_dist)
            
            # Log new detections to session state (throttled to once every 3 seconds per person)
            if name != "Unknown":
                now = datetime.now()
                last_logged = [x for x in st.session_state.detection_log if x["name"] == name]
                if not last_logged or (now - last_logged[-1]["time"]).total_seconds() > 3.0:
                    # Save a thumbnail of the detected face
                    try:
                        # Scale coordinates back up to original frame
                        top, right, bottom, left = face_locations[len(face_names)-1]
                        top, right, bottom, left = top * cv_scaler, right * cv_scaler, bottom * cv_scaler, left * cv_scaler
                        face_crop = frame[max(0, top-20):min(480, bottom+20), max(0, left-20):min(640, right+20)]
                        
                        # Encode to jpg bytes for web display
                        _, encoded_img = cv2.imencode('.jpg', face_crop)
                        thumb_bytes = encoded_img.tobytes()
                    except Exception:
                        thumb_bytes = None
                        
                    st.session_state.detection_log.insert(0, {
                        "name": name,
                        "time": now,
                        "confidence": f"{max(0, int((1.0 - best_dist) * 100))}%",
                        "status": "APPROVED" if name in authorized_names else "BLOCKED",
                        "thumbnail": thumb_bytes
                    })
                    
                    # Limit log length to 20
                    if len(st.session_state.detection_log) > 20:
                        st.session_state.detection_log.pop()
        
        latency = time.time() - start_time
        
        with lock:
            shared["locations"] = face_locations
            shared["names"] = face_names
            shared["distances"] = face_distances
            shared["processing_time"] = latency
            
        time.sleep(0.02)
# Start recognition worker thread if not running
if "worker_thread" not in st.session_state:
