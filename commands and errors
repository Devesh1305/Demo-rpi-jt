# Draw HUD Scanning Bracket on Face Bounding Box (Wow factor)
def draw_sci_fi_hud(img, left, top, right, bottom, name, confidence, authorized):
    color = (240, 230, 20) if authorized else (30, 30, 240) # Neon Cyan (B,G,R) vs Neon Red
    
    # Bounding Box Corners (futuristic HUD look)
    length = 20
    thickness = 3
    
    # Draw corners
    # Top-Left
    cv2.line(img, (left, top), (left + length, top), color, thickness)
    cv2.line(img, (left, top), (left, top + length), color, thickness)
    # Top-Right
    cv2.line(img, (right, top), (right - length, top), color, thickness)
    cv2.line(img, (right, top), (right, top + length), color, thickness)
    # Bottom-Left
    cv2.line(img, (left, bottom), (left + length, bottom), color, thickness)
    cv2.line(img, (left, bottom), (left, bottom - length), color, thickness)
    # Bottom-Right
    cv2.line(img, (right, bottom), (right - length, bottom), color, thickness)
    cv2.line(img, (right, bottom), (right, bottom - length), color, thickness)
    
    # Subtly fill face area with alpha mask
    face_roi = img[top:bottom, left:right]
    overlay = face_roi.copy()
    cv2.rectangle(overlay, (0, 0), (right - left, bottom - top), color, -1)
    # Blending frame
    cv2.addWeighted(overlay, 0.08, face_roi, 0.92, 0, face_roi)
    
    # HUD details - Target reticle lines
    cv2.drawMarker(img, (int((left+right)/2), int((top+bottom)/2)), color, cv2.MARKER_CROSS, 15, 1)
    
    # Hologram Text Labels
    font = cv2.FONT_HERSHEY_SIMPLEX
    font_scale = 0.55
    text_color = (255, 255, 255)
    
    # Status Tag
    tag = "ACCESS APPROVED" if authorized else "WARNING: UNKNOWN"
    cv2.putText(img, f"ID: {name.upper()}", (left, top - 25), font, font_scale, color, 2)
    cv2.putText(img, f"MATCH: {confidence}", (left, top - 8), font, font_scale, text_color, 1)
    cv2.putText(img, tag, (left, bottom + 18), font, 0.45, color, 1)
