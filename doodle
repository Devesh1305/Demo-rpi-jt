# ==========================================
with tab_canvas:
    run_stream = st.checkbox("▶️ Start Webcam & Drawing Stream", value=False)
    
    # Grid Layout
    col_feed, col_hud = st.columns([5, 3])
    
    with col_feed:
        video_placeholder = st.empty()
        
    with col_hud:
        st.markdown("### 📊 Performance HUD")
        fps_placeholder = st.empty()
        mode_placeholder = st.empty()
        active_color_placeholder = st.empty()
        
        st.markdown("#### Gestures Legend")
        st.info("""
        * **1 Finger Up (Index):** Drawing Mode ✏️
        * **2 Fingers Up (Index + Middle):** Selection Mode 🎯 *(Hover over top menu color to switch, hover over CLEAR to wipe)*
        * **Closed Hand:** Paused Mode ⏸️
        """)
    # Setup or retrieve background capture thread
    if run_stream:
        # Check if camera index changed
        if 'current_camera_idx' not in st.session_state:
            st.session_state.current_camera_idx = camera_idx
        if st.session_state.current_camera_idx != camera_idx or 'cam' not in st.session_state or st.session_state.cam is None:
            if 'cam' in st.session_state and st.session_state.cam is not None:
                st.session_state.cam.close()
            st.session_state.cam = USBWebcamPipe(camera_idx=camera_idx, width=WIDTH, height=HEIGHT)
            st.session_state.current_camera_idx = camera_idx
        cam = st.session_state.cam
        
        # Timing trackers
        fps_history = []
        last_time = time.perf_counter()
        
        # Main run loop
        while run_stream:
            frame = cam.get_latest_frame()
            if frame is None:
                time.sleep(0.01)
                continue
            
            # Mirror selfie view if enabled
            if mirror_view:
                frame = cv2.flip(frame, 1)
            # Frame dimensions
            h, w = frame.shape[:2]
            # Draw top selection headers
            step = w // 5
            for i, col in enumerate(COLORS):
                x_start, x_end = i * step, (i + 1) * step
                if i == 4:
                    cv2.rectangle(frame, (x_start, 0), (x_end, 50), (200, 200, 200), -1)
                    cv2.putText(frame, "CLEAR", (x_start + 25, 33), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 0, 0), 2)
                else:
                    cv2.rectangle(frame, (x_start, 0), (x_end, 50), col, -1)
                    # Border highlights active color
                    if i == st.session_state.color_idx:
                        cv2.rectangle(frame, (x_start, 0), (x_end, 50), (255, 255, 255), 4)
            # Process hand detection
            rgb_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            results = hands.process(rgb_frame)
            current_mode = "Paused ⏸️"
            
            if results.multi_hand_landmarks:
                for hand_landmarks in results.multi_hand_landmarks:
                    lm = hand_landmarks.landmark
                    
                    # Convert normalized coords to pixels
                    x1, y1 = int(lm[8].x * w), int(lm[8].y * h)   # Index fingertip
                    x2, y2 = int(lm[12].x * w), int(lm[12].y * h) # Middle fingertip
                    # Gestures detection flags
                    index_up = lm[8].y < lm[6].y
                    middle_up = lm[12].y < lm[10].y
                    ring_up = lm[16].y < lm[14].y
                    # Mode 2: Color Selection Mode (Index + Middle fingers are raised)
                    if index_up and middle_up and not ring_up:
                        current_mode = "Selecting Color/Action 🎯"
                        st.session_state.xp, st.session_state.yp = 0, 0 # Reset continuous lines
                        
                        # Draw selection line/sight between fingertips
                        cv2.line(frame, (x1, y1), (x2, y2), COLORS[st.session_state.color_idx], 3)
                        cv2.circle(frame, (x1, y1), 8, COLORS[st.session_state.color_idx], -1)
                        cv2.circle(frame, (x2, y2), 8, COLORS[st.session_state.color_idx], -1)
                        
                        # Selection menu hit box
                        if y1 < 50:
                            selected_box = x1 // step
                            if selected_box == 4:
                                st.session_state.canvas = np.zeros((HEIGHT, WIDTH, 3), dtype=np.uint8)
                                st.session_state.xp, st.session_state.yp = 0, 0
                            else:
                                st.session_state.color_idx = selected_box
                    # Mode 1: Drawing Mode (Only Index finger is raised)
                    elif index_up and not middle_up:
                        current_mode = "Drawing ✏️"
                        
                        # Draw pointer indicator
                        cv2.circle(frame, (x1, y1), brush_size + 4, COLORS[st.session_state.color_idx], -1)
                        cv2.circle(frame, (x1, y1), brush_size + 6, (255, 255, 255), 2)
                        if st.session_state.xp == 0 and st.session_state.yp == 0:
                            st.session_state.xp, st.session_state.yp = x1, y1
                        # Glitch protector (avoids drawing long warp lines if hand tracker jumps)
                        dist = math.hypot(x1 - st.session_state.xp, y1 - st.session_state.yp)
                        if dist < 100:
                            cv2.line(
                                st.session_state.canvas, 
                                (st.session_state.xp, st.session_state.yp), 
                                (x1, y1), 
                                COLORS[st.session_state.color_idx], 
                                brush_size
                            )
                        st.session_state.xp, st.session_state.yp = x1, y1
                    else:
                        # Closed hand or other gesture; break drawing line
                        st.session_state.xp, st.session_state.yp = 0, 0
            else:
                st.session_state.xp, st.session_state.yp = 0, 0
            # Merge persistent drawing canvas with current frame (black pixels are transparent)
            paint_mask = st.session_state.canvas.any(axis=-1)
            frame[paint_mask] = st.session_state.canvas[paint_mask]
            # Render frame
            video_placeholder.image(frame, channels="BGR", use_container_width=True)
            # Performance HUD metrics update
            now = time.perf_counter()
            fps = 1.0 / (now - last_time) if (now - last_time) > 0 else 0
            last_time = now
            fps_history.append(fps)
            if len(fps_history) > 30:
                fps_history.pop(0)
            avg_fps = np.mean(fps_history)
            fps_placeholder.markdown(f"""
                <div class="metric-container">
                    <div class="metric-label">Pipeline Frame Rate</div>
                    <div class="metric-value">{avg_fps:.1f} FPS</div>
                    <div class="metric-sub">MediaPipe + OpenCV Processing</div>
                </div>
            """, unsafe_allow_html=True)
            
            mode_placeholder.markdown(f"""
                <div class="metric-container">
                    <div class="metric-label">Active State</div>
                    <div class="metric-value" style="color: #0984e3;">{current_mode}</div>
                    <div class="metric-sub">Derived from finger landmark configuration</div>
                </div>
            """, unsafe_allow_html=True)
            active_col = COLOR_NAMES[st.session_state.color_idx]
            rgb_col = COLORS[st.session_state.color_idx]
            active_color_placeholder.markdown(f"""
                <div class="metric-container">
                    <div class="metric-label">Brush Color</div>
                    <div class="metric-value" style="color: rgb{rgb_col};">{active_col}</div>
                    <div class="metric-sub">Brush Size: {brush_size} px</div>
                </div>
            """, unsafe_allow_html=True)
            time.sleep(0.01)
    else:
        st.info("💡 Check the box above to start the webcam pipeline.")
        # Cleanup camera thread on stop
        if 'cam' in st.session_state and st.session_state.cam is not None:
            st.session_state.cam.close()
            st.session_state.cam = None
